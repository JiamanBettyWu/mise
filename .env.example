# Backend (Render env vars) ----------------------------------------------

# Supabase: Project Settings -> API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...           # service_role key (server-side only, never ship to frontend)

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenWeatherMap (Phase 3)
OPENWEATHERMAP_API_KEY=
WEATHER_LAT=                                # e.g. 37.7749
WEATHER_LON=                                # e.g. -122.4194

# Single-user auth — pick any string and use the same value in the frontend
APP_PASSWORD=change-me

# CORS — comma-separated list of frontend origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:5173,https://YOUR-VERCEL-DOMAIN.vercel.app

# Email (Phase 4)
GMAIL_SENDER=
GMAIL_APP_PASSWORD=                         # Google Account -> Security -> App passwords
EMAIL_RECIPIENT=

# Email feedback links (#39). FEEDBACK_SECRET must be IDENTICAL here, in Render,
# and in GitHub Actions secrets — the daily job signs tokens, Render verifies.
FEEDBACK_SECRET=
BACKEND_PUBLIC_URL=https://YOUR-RENDER-APP.onrender.com   # base URL for the 👍/👎 links

# Calendar-driven modes (#64, optional). Google Calendar -> Settings ->
# "Secret address in iCal format". Presence of this var is the on/off toggle.
CALENDAR_ICS_URL=

# Frontend (Vercel env vars) ---------------------------------------------

# Note: only VITE_* vars are exposed to the browser. Don't put secrets here
# beyond APP_PASSWORD (which is a shared secret by design in this single-user app).
VITE_API_BASE_URL=https://YOUR-RENDER-APP.onrender.com

# Serpapi
SERPAPI_API_KEY=